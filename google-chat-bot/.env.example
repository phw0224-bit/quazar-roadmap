# ─── Supabase ────────────────────────────────────────────────────
# Supabase 프로젝트 URL (기존 .env의 VITE_SUPABASE_URL과 동일)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# service_role key (⚠️ anon key 아님! Supabase 대시보드 → Settings → API)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Ollama (Mac Mini M4) ────────────────────────────────────────
# 회사 Mac Mini M4의 IP 주소 (예: 192.168.1.xxx)
# 집에서 테스트할 때는 localhost로
OLLAMA_URL=http://192.168.1.xxx:11434

# 사용할 모델 (ollama list 로 확인)
OLLAMA_MODEL=qwen2.5:14b

# ─── 봇 서버 ────────────────────────────────────────────────────
PORT=3002
