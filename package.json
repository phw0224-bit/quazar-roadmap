{
  "name": "roadmap",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "pub": "vite --port 1234",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview --port 1234",
    "server": "node server/index.js",
    "dev:all": "concurrently --names \"WEB,SRV\" --prefix-colors \"cyan,yellow\" --kill-others-on-fail \"yarn dev\" \"yarn server\"",
    "prod:all": "yarn build && concurrently --names \"WEB,SRV\" --prefix-colors \"cyan,yellow\" --kill-others-on-fail \"yarn preview\" \"yarn server\"",
    "supabase:selfhost:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-supabase-selfhost.ps1",
    "supabase:selfhost:up": "docker compose --env-file infra/supabase-selfhost/.env -f infra/supabase-selfhost/docker-compose.yml up -d",
    "supabase:selfhost:down": "docker compose --env-file infra/supabase-selfhost/.env -f infra/supabase-selfhost/docker-compose.yml down",
    "supabase:selfhost:ps": "docker compose --env-file infra/supabase-selfhost/.env -f infra/supabase-selfhost/docker-compose.yml ps",
    "supabase:export": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/export-supabase-cloud.ps1",
    "supabase:restore": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/restore-local-supabase.ps1"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.99.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/core": "^3.20.5",
    "@tiptap/extension-code-block-lowlight": "^3.21.0",
    "@tiptap/extension-color": "^3.21.0",
    "@tiptap/extension-highlight": "^3.21.0",
    "@tiptap/extension-image": "^3.20.5",
    "@tiptap/extension-link": "^3.21.0",
    "@tiptap/extension-mention": "^3.21.0",
    "@tiptap/extension-placeholder": "^3.20.5",
    "@tiptap/extension-table": "^3.20.5",
    "@tiptap/extension-table-cell": "^3.20.5",
    "@tiptap/extension-table-header": "^3.20.5",
    "@tiptap/extension-table-row": "^3.20.5",
    "@tiptap/extension-task-item": "^3.21.0",
    "@tiptap/extension-task-list": "^3.21.0",
    "@tiptap/extension-text-style": "^3.21.0",
    "@tiptap/extension-underline": "^3.21.0",
    "@tiptap/pm": "^3.20.5",
    "@tiptap/react": "^3.20.5",
    "@tiptap/starter-kit": "^3.20.5",
    "@tiptap/suggestion": "^3.21.0",
    "@uiw/react-codemirror": "^4.25.9",
    "axios": "^1.13.6",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "katex": "^0.16.45",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.5",
    "marked-footnote": "^1.4.0",
    "mermaid": "^11.14.0",
    "multer": "^2.1.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "remark-gfm": "^4.0.1",
    "tippy.js": "^6.3.7",
    "tiptap-extension-global-drag-handle": "^0.1.18",
    "turndown": "^7.2.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
